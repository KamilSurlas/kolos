#ifdef Zadanie3
int ileLiter(char * tekst, char znak)
{	
	int ile = 0;
	for (int i = 0; i < 100; i++)
	{
		if (tekst[i] == znak)
			ile++;
		else if(!isalpha(tekst[i]))
		{
			cout << "invalid_argument";
				break;
		}
	}
	return ile;
}

int main() 
{
	char tekst[100];
	cout << "Podaj tekst nie dluzszy niz 100 lier";
	cin >> tekst;
	cout << "W tekscie 'x' znajduje sie:" << ileLiter(tekst, 'x');
}
